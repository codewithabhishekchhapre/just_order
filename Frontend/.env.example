# ==========================================
# Frontend Environment Variables
# Copy this file to .env and update the values
# ==========================================

# ==========================================
# API Configuration
# Backend API (same port as backend)
# ==========================================
VITE_API_BASE_URL=http://localhost:5001/api/v1
VITE_BACKEND_PROXY_TARGET=http://localhost:5001

# ==========================================
# Google Maps Configuration
# ==========================================
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
VITE_ENABLE_MAP_SIMULATION=true
VITE_ENABLE_NOMINATIM_SEARCH=true

# ==========================================
# Razorpay Configuration
# ==========================================
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id

# ==========================================
# Firebase Configuration
# ==========================================
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
VITE_FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com/
VITE_FIREBASE_VAPID_KEY=your_firebase_vapid_key

# ==========================================
# Development Options
# ==========================================
VITE_APP_MODE=development
VITE_ENABLE_RANGE_BYPASS=true